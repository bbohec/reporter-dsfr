{
  "name": "reporter-dsfr",
  "version": "0.0.0",
  "description": "🇫🇷 A French Government Design system test reporter",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
 "exports": {
    ".": {
      "types": "./dist/index.d.ts", 
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "jest-reporter",
    "vitest-reporter",
    "test-reporter",
    "typescript",
    "dsfr"
  ],
  "author": {
    "name": "u/bbohec"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@jest/reporters": "^29.0.0",
    "@jest/test-result": "^29.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@jest/reporters": ">=27",
    "vitest": ">=1"
  },
  "peerDependenciesMeta": {
    "@jest/reporters": { "optional": true },
    "vitest": { "optional": true }
  }
}